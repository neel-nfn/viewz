{
  "dashboard": {
    "title": "Viewz Backend Metrics",
    "tags": ["viewz", "backend"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "HTTP Requests Total",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(rate(http_requests_total[5m])) by (path, method)",
            "legendFormat": "{{path}} {{method}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "5xx Errors",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(rate(http_5xx_total[5m]))",
            "legendFormat": "5xx rate"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "alert": {
          "conditions": [
            {
              "evaluator": {"params": [1], "type": "gt"},
              "operator": {"type": "and"},
              "query": {"params": ["A", "5m", "now"]},
              "reducer": {"params": [], "type": "last"},
              "type": "query"
            }
          ]
        }
      },
      {
        "id": 3,
        "title": "Auth Failures",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(rate(auth_failures_total[5m]))",
            "legendFormat": "Auth failures rate"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "alert": {
          "conditions": [
            {
              "evaluator": {"params": [5], "type": "gt"},
              "operator": {"type": "and"},
              "query": {"params": ["A", "5m", "now"]},
              "reducer": {"params": [], "type": "last"},
              "type": "query"
            }
          ]
        }
      },
      {
        "id": 4,
        "title": "Request Latency (p95)",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, path, method))",
            "legendFormat": "p95 {{path}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      }
    ],
    "refresh": "30s",
    "schemaVersion": 16,
    "version": 1
  }
}

